# VetWraps Studios - Vercel Environment Variables Template
# Copy these to your Vercel project → Settings → Environment Variables
# Replace all placeholder values with your actual API keys

# Database (Supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# AI (OpenAI)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Authentication (Clerk)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Payments (Stripe) - Optional
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Email Services - Optional
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
RESEND_API_KEY=re_your_resend_api_key_here

# App Configuration
DEBUG=False
ENVIRONMENT=production
